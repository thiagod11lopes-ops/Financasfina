rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /userFinances/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Lista de Compras (sala = hash SHA-256 de 64 hex)
    match /listaComprasSync_v1/{docId} {
      allow read, write: if docId.size() == 64 && docId.matches('^[a-f0-9]+$');
    }

    match /listaComprasVerSomente_v1/{docId} {
      allow read: if true;
      allow create: if docId.size() == 64
        && docId.matches('^[a-f0-9]+$')
        && request.resource.data.keys().hasAll(['payload', 'criadoEm'])
        && request.resource.data.payload is string
        && request.resource.data.payload.size() < 900000
        && request.resource.data.criadoEm is int;
      allow update, delete: if false;
    }
  }
}
